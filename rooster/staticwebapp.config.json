{
  "routes": [
    {
      "route": "/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "auth": {
    "identityProviders": {
      "azureActiveDirectory": {
        "registration": {
          "openIdConnectConfiguration": {
            "customParameters": {
              "claims": "{\"id_token\":{\"auth_context_class_reference\":{\"essential\":true,\"value\":\"C2\"}}}"
            }
          }
        }
      }
    }
  }
}
